# FAI Factory Configuration
# FROOTAI_PUBLIC_REPO=../frootai          # Path to public repo (for open-core setup)
# FROOTAI_WEBSITE_REPO=../frootai.dev     # Path to website repo (for website adapter)

# MCP Server Configuration
# FAI_TOOLSET=full                        # Tool visibility: full|core|minimal
# FAI_ENV=production                      # Environment: development|production

# Rate Limiting
# FAI_RATE_LIMIT_RPM=60                   # Requests per minute
# FAI_RATE_LIMIT_BURST=10                 # Burst allowance

# Auto-Update
# FAI_AUTO_UPDATE=true                    # Enable knowledge auto-update from GitHub
# FAI_UPDATE_INTERVAL=7                   # Days between update checks
