{
  "version": 1,
  "hooks": [
    {
      "event": "preToolUse",
      "command": "echo 'Guardrail check for ${slug}'",
      "description": "Validates tool calls for Ai Data Pipeline against security and cost policies",
      "timeout": 10000,
      "mode": "warn",
      "rules": {
        "blocked_tools": [
          "rm -rf",
          "DROP TABLE",
          "kubectl delete namespace"
        ],
        "require_approval": [
          "az group delete",
          "az resource delete"
        ],
        "max_cost_per_call": 0.05,
        "content_safety": {
          "enabled": true,
          "severity_threshold": 2
        },
        "allowed_azure_services": [
          "Azure OpenAI",
          "Azure Data Factory",
          "Azure Blob Storage",
          "Azure Event Hubs",
          "Azure Cosmos DB",
          "Azure Monitor"
        ],
        "pii_protection": {
          "enabled": true,
          "action": "redact"
        }
      }
    },
    {
      "event": "sessionEnd",
      "command": "echo 'Session audit for ${slug}'",
      "description": "Audit trail for Ai Data Pipeline session — logs tool calls, costs, and safety events",
      "timeout": 5000,
      "mode": "info"
    }
  ]
}