    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "environment": {
      "type": "string",
      "defaultValue": "dev",
      "allowedValues": [
        "dev",
        "staging",
        "prod"
      ],
      "metadata": {
        "description": "Environment: dev, staging, or prod"
      }
    },
    "vnetAddressPrefix": {
      "type": "string",
      "defaultValue": "10.0.0.0/16",
      "metadata": {
        "description": "Address prefix for the virtual network (CIDR)"
      }
    }
  },
  "variables": {
    "suffix": "[uniqueString(resourceGroup().id)]",
    "tags": {
      "environment": "[parameters('environment')]",
      "project": "frootai",
      "play": "02-ai-landing-zone"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2024-01-01",
      "name": "[format('frootai-lz-nsg-{0}', variables('suffix'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "securityRules": [
          {
            "name": "DenyAllInbound",
            "properties": {
              "priority": 4096,
              "direction": "Inbound",
              "access": "Deny",
              "protocol": "*",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "*"
            }
          },
          {
            "name": "AllowVnetInbound",
            "properties": {
              "priority": 100,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "*",
              "sourceAddressPrefix": "VirtualNetwork",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "VirtualNetwork",
              "destinationPortRange": "*"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2024-01-01",
      "name": "[format('frootai-lz-vnet-{0}', variables('suffix'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[parameters('vnetAddressPrefix')]"
          ]
        },
        "subnets": [
          {
            "name": "ai-services",
            "properties": {
              "addressPrefix": "[cidrSubnet(parameters('vnetAddressPrefix'), 24, 0)]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', format('frootai-lz-nsg-{0}', variables('suffix')))]"
              }
            }
          },
          {
            "name": "private-endpoints",
            "properties": {
              "addressPrefix": "[cidrSubnet(parameters('vnetAddressPrefix'), 24, 1)]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', format('frootai-lz-nsg-{0}', variables('suffix')))]"
              }
            }
          },
          {
            "name": "compute",
            "properties": {
              "addressPrefix": "[cidrSubnet(parameters('vnetAddressPrefix'), 24, 2)]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', format('frootai-lz-nsg-{0}', variables('suffix')))]"
              },
              "delegations": [
                {
                  "name": "containerApps",
                  "properties": {
                    "serviceName": "Microsoft.App/environments"
                  }
                }
              ]
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', format('frootai-lz-nsg-{0}', variables('suffix')))]"
      ]
    },
    {
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2024-06-01",
      "name": "privatelink.openai.azure.com",
      "location": "global",
      "tags": "[variables('tags')]"
    },
    {
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2024-06-01",
      "name": "[format('{0}/{1}', 'privatelink.openai.azure.com', 'openai-vnet-link')]",
      "location": "global",
      "properties": {
        "virtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', format('frootai-lz-vnet-{0}', variables('suffix')))]"
        },
        "registrationEnabled": false
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.openai.azure.com')]",
        "[resourceId('Microsoft.Network/virtualNetworks', format('frootai-lz-vnet-{0}', variables('suffix')))]"
      ]
    },
    {
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2024-06-01",
      "name": "privatelink.search.windows.net",
      "location": "global",
      "tags": "[variables('tags')]"
    },
    {
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2024-06-01",
      "name": "[format('{0}/{1}', 'privatelink.search.windows.net', 'search-vnet-link')]",
      "location": "global",
      "properties": {
        "virtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', format('frootai-lz-vnet-{0}', variables('suffix')))]"
        },
        "registrationEnabled": false
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.search.windows.net')]",
        "[resourceId('Microsoft.Network/virtualNetworks', format('frootai-lz-vnet-{0}', variables('suffix')))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[format('frootai-kv-{0}', variables('suffix'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "tenantId": "[subscription().tenantId]",
        "enableRbacAuthorization": true,
        "enableSoftDelete": true,
        "softDeleteRetentionInDays": 90,
        "publicNetworkAccess": "Disabled",
        "networkAcls": {
          "defaultAction": "Deny",
          "bypass": "AzureServices"
        }
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[format('frootai-lz-law-{0}', variables('suffix'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 90
      }
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('frootai-lz-id-{0}', variables('suffix'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]"
    }
  ],
  "outputs": {
    "vnetId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/virtualNetworks', format('frootai-lz-vnet-{0}', variables('suffix')))]"
    },
    "aiServicesSubnetId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/virtualNetworks', format('frootai-lz-vnet-{0}', variables('suffix'))), '2024-01-01').subnets[0].id]"
    },
    "privateEndpointsSubnetId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/virtualNetworks', format('frootai-lz-vnet-{0}', variables('suffix'))), '2024-01-01').subnets[1].id]"
    },
    "computeSubnetId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/virtualNetworks', format('frootai-lz-vnet-{0}', variables('suffix'))), '2024-01-01').subnets[2].id]"
    },
    "keyVaultUri": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.KeyVault/vaults', format('frootai-kv-{0}', variables('suffix'))), '2023-07-01').vaultUri]"
    },
    "logAnalyticsWorkspaceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.OperationalInsights/workspaces', format('frootai-lz-law-{0}', variables('suffix')))]"
    },
    "identityClientId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('frootai-lz-id-{0}', variables('suffix'))), '2023-01-31').clientId]"
    },
    "dnsOpenAIZoneId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.openai.azure.com')]"
    },
    "dnsSearchZoneId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.search.windows.net')]"
    }
  }
}