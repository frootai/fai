{
  "name": "24-ai-code-review-pipeline",
  "version": "1.0.0",
  "framework": "frootai",
  "title": "AI Code Review Pipeline",
  "description": "Automated PR review with CodeQL integration, OWASP scanning, architecture validation, and AI-generated improvement suggestions with inline comments.",
  "complexity": "Medium",
  "tags": [
    "security",
    "reliability",
    "operational-excellence",
    "responsible-ai"
  ],
  "status": "Active",
  "kits": {
    "devkit": {
      "path": ".github/",
      "includes": [
        "agents",
        "instructions",
        "prompts",
        "skills"
      ]
    },
    "tunekit": {
      "path": "config/",
      "files": [
        "openai.json",
        "guardrails.json"
      ]
    },
    "speckit": {
      "path": "spec/",
      "files": [
        "play-spec.json"
      ]
    }
  }
}
