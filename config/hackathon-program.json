{
  "program": "FrootAI Community Hackathons",
  "version": "1.0.0",
  "description": "Monthly virtual hackathons themed by domain to drive community contributions and grow the primitive ecosystem toward 1000+",
  "schedule": "Last Saturday of each month, 09:00-17:00 UTC",
  "platform": "GitHub + Discord + frootai.dev/community",
  "prizes": {
    "1st": "Featured on frootai.dev homepage + FrootAI swag kit + FAI Expert fast-track",
    "2nd": "Featured contributor badge + FrootAI swag",
    "3rd": "Contributor badge + mention in changelog",
    "best_newcomer": "Mentorship session with core team"
  },
  "themes": [
    {
      "month": "May 2026",
      "theme": "RAG & Search Primitives",
      "focus": "New agents, skills, and plugins for retrieval-augmented generation",
      "target_primitives": 15
    },
    {
      "month": "Jun 2026",
      "theme": "Multi-Agent Patterns",
      "focus": "Agent orchestration, delegation, handoff primitives",
      "target_primitives": 15
    },
    {
      "month": "Jul 2026",
      "theme": "Voice & Media AI",
      "focus": "Speech-to-text, text-to-speech, video processing primitives",
      "target_primitives": 10
    },
    {
      "month": "Aug 2026",
      "theme": "Healthcare & Life Sciences",
      "focus": "HIPAA-compliant agents, clinical coding, drug interaction primitives",
      "target_primitives": 10
    },
    {
      "month": "Sep 2026",
      "theme": "Financial Services",
      "focus": "Risk analysis, fraud detection, regulatory compliance primitives",
      "target_primitives": 10
    },
    {
      "month": "Oct 2026",
      "theme": "Partner Integrations",
      "focus": "ServiceNow, Salesforce, SAP, Jira, Slack, Teams plugins",
      "target_primitives": 15
    },
    {
      "month": "Nov 2026",
      "theme": "Edge & IoT AI",
      "focus": "On-device inference, ONNX, IoT Hub, edge deployment primitives",
      "target_primitives": 10
    },
    {
      "month": "Dec 2026",
      "theme": "Open Innovation",
      "focus": "Any domain — surprise us with novel AI primitives",
      "target_primitives": 15
    }
  ],
  "rules": {
    "eligibility": "Anyone with a GitHub account",
    "submission": "Pull request to frootai/frootai repo following CONTRIBUTING.md",
    "requirements": [
      "All primitives must follow naming conventions (lowercase-hyphen)",
      "Frontmatter must have all required fields per type",
      "npm run validate:primitives must pass with 0 errors",
      "No secrets, API keys, or connection strings in any file",
      "WAF pillar references must use valid 6-pillar values",
      "Include README.md or documentation for new primitives"
    ],
    "judging_criteria": [
      {
        "criterion": "Quality",
        "weight": 30,
        "description": "Code quality, documentation, WAF alignment"
      },
      {
        "criterion": "Originality",
        "weight": 25,
        "description": "Novel approach, creative problem solving"
      },
      {
        "criterion": "Usefulness",
        "weight": 25,
        "description": "Practical value for AI developers"
      },
      {
        "criterion": "Completeness",
        "weight": 20,
        "description": "Full primitive with tests, docs, examples"
      }
    ]
  },
  "mentorship": {
    "office_hours": "Wednesdays 16:00 UTC on Discord",
    "topics": [
      "Primitive creation",
      "MCP tool development",
      "Play architecture",
      "FAI Protocol"
    ],
    "mentors": "Core team + FAI Expert certified community members"
  },
  "infrastructure": {
    "github": {
      "label": "hackathon",
      "project_board": "FrootAI Hackathon Submissions",
      "issue_template": "hackathon-submission.yml"
    },
    "discord": {
      "channel": "#hackathon",
      "announcements": "#announcements",
      "help": "#hackathon-help"
    },
    "website": {
      "page": "frootai.dev/community/hackathon",
      "leaderboard": "frootai.dev/community/leaderboard",
      "submissions": "frootai.dev/community/hackathon/submissions"
    }
  },
  "growth_target": {
    "q2_2026": {
      "hackathons": 2,
      "expected_primitives": 30,
      "cumulative": 846
    },
    "q3_2026": {
      "hackathons": 3,
      "expected_primitives": 35,
      "cumulative": 881
    },
    "q4_2026": {
      "hackathons": 3,
      "expected_primitives": 40,
      "cumulative": 921
    },
    "q1_2027": {
      "hackathons": 3,
      "expected_primitives": 80,
      "cumulative": 1001,
      "milestone": "1000+ PRIMITIVES ACHIEVED"
    }
  }
}